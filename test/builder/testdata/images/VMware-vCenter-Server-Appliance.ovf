      <vmw:ExtraConfig ovf:required="false" vmw:key="msg.autoAnswer" vmw:value="TRUE"/>
      <vmw:ExtraConfig ovf:required="false" vmw:key="cdrom.showIsoLockWarning" vmw:value="FALSE"/>
      <!--
      The flags acpi.smbiosVersion2.7 and vmxnet3.serialNumberV2 are set to FALSE to keep the behaviour
      same against the previous vmx versions (vmx < 13). This will be removed in vc10GA once we move away
      from using bios uuid to identify the vc.
      -->
      <vmw:ExtraConfig ovf:required="false" vmw:key="acpi.smbiosVersion2.7" vmw:value="FALSE"/>
      <vmw:ExtraConfig ovf:required="false" vmw:key="vmxnet3.serialNumberV2" vmw:value="FALSE"/>
      <!--End of temporary ExtraConfig flags-->
      <vmw:Config vmw:key="cpuHotAddEnabled" vmw:value="true"/>
      <vmw:Config vmw:key="cpuHotRemoveEnabled" vmw:value="true"/>
      <vmw:Config vmw:key="memoryHotAddEnabled" vmw:value="true"/>
