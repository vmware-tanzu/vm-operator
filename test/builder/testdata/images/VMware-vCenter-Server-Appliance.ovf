  <DeploymentOptionSection>
    <Info>List of profiles</Info>
    <Configuration ovf:id="internal-minimal">
      <Label>Internal Minimal vCenter Server with Embedded PSC</Label>
      <Description>This will deploy a Internal Minimal VM configured with 2 vCPUs and 12.5 GB of memory and requires 604 GB of disk space. This option contains vCenter Server with an embedded Platform Services Controller for managing up to 10 hosts and 100 VMs.</Description>
    </Configuration>
    <Configuration ovf:default="true" ovf:id="tiny">
      <Label>Tiny vCenter Server with Embedded PSC</Label>
      <Description>This will deploy a Tiny VM configured with 2 vCPUs and 14 GB of memory and requires 604 GB of disk space. This option contains vCenter Server with an embedded Platform Services Controller for managing up to 10 hosts and 100 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="small">
      <Label>Small vCenter Server with Embedded PSC</Label>
      <Description>This will deploy a Small VM configured with 4 vCPUs and 21 GB of memory and requires 694 GB of disk space. This option contains vCenter Server with an embedded Platform Services Controller for managing up to 100 hosts and 1,000 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="medium">
      <Label>Medium vCenter Server with Embedded PSC</Label>
      <Description>This will deploy a Medium VM configured with 8 vCPUs and 30 GB of memory and requires 858 GB of disk space. This option contains vCenter Server with an embedded Platform Services Controller for managing up to 400 hosts and 4,000 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="large">
      <Label>Large vCenter Server with Embedded PSC</Label>
      <Description>This will deploy a Large VM configured with 16 vCPUs and 39 GB of memory and requires 1158 GB of disk space. This option contains vCenter Server with an embedded Platform Services Controller for managing up to 1000 hosts and 10,000 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="xlarge">
      <Label>X-Large vCenter Server with Embedded PSC</Label>
      <Description>This will deploy a X-Large VM configured with 24 vCPUs and 58 GB of memory and requires 1783 GB of disk space will be updated for xlarge later. This option contains vCenter Server with an embedded Platform Services Controller for managing up to 2000 hosts and 35,000 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="tiny-lstorage">
      <Label>Tiny vCenter Server with Embedded PSC (large storage)</Label>
      <Description>This will deploy a Tiny VM configured with 2 vCPUs and 14 GB of memory and requires 1494 GB of disk space. This option contains vCenter Server with an embedded Platform Services Controller for managing up to 10 hosts and 100 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="small-lstorage">
      <Label>Small vCenter Server with Embedded PSC (large storage)</Label>
      <Description>This will deploy a Small VM configured with 4 vCPUs and 21 GB of memory and requires 1519 GB of disk space. This option contains vCenter Server with an embedded Platform Services Controller for managing up to 100 hosts and 1,000 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="medium-lstorage">
      <Label>Medium vCenter Server with Embedded PSC (large storage)</Label>
      <Description>This will deploy a Medium VM configured with 8 vCPUs and 30 GB of memory and requires 1658 GB of disk space. This option contains vCenter Server with an embedded Platform Services Controller for managing up to 400 hosts and 4,000 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="large-lstorage">
      <Label>Large vCenter Server with Embedded PSC (large storage)</Label>
      <Description>This will deploy a Large VM configured with 16 vCPUs and 39 GB of memory and requires 1708 GB of disk space. This option contains vCenter Server with an embedded Platform Services Controller for managing up to 1000 hosts and 10,000 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="xlarge-lstorage">
      <Label>X-Large vCenter Server with Embedded PSC (large storage)</Label>
      <Description>This will deploy a X-Large VM configured with 24 vCPUs and 58 GB of memory and requires 1833 GB of disk space. This option contains vCenter Server with an embedded Platform Services Controller for managing up to 2000 hosts and 35,000 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="tiny-xlstorage">
      <Label>Tiny vCenter Server with Embedded PSC (x-large storage)</Label>
      <Description>This will deploy a Tiny VM configured with 2 vCPUs and 14 GB of memory and requires 2874 GB of disk space. This option contains vCenter Server with an embedded Platform Services Controller for managing up to 10 hosts and 100 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="small-xlstorage">
      <Label>Small vCenter Server with Embedded PSC (x-large storage)</Label>
      <Description>This will deploy a Small VM configured with 4 vCPUs and 21 GB of memory and requires 2899 GB of disk space. This option contains vCenter Server with an embedded Platform Services Controller for managing up to 100 hosts and 1,000 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="medium-xlstorage">
      <Label>Medium vCenter Server with Embedded PSC (x-large storage)</Label>
      <Description>This will deploy a Medium VM configured with 8 vCPUs and 30 GB of memory and requires 3038 GB of disk space. This option contains vCenter Server with an embedded Platform Services Controller for managing up to 400 hosts and 4,000 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="large-xlstorage">
      <Label>Large vCenter Server with Embedded PSC (x-large storage)</Label>
      <Description>This will deploy a Large VM configured with 16 vCPUs and 39 GB of memory and requires 3088 GB of disk space. This option contains vCenter Server with an embedded Platform Services Controller for managing up to 1000 hosts and 10,000 VMs.</Description>
    </Configuration>
    <Configuration ovf:id="xlarge-xlstorage">
      <Label>X-Large vCenter Server with Embedded PSC (x-large storage)</Label>
      <Description>This will deploy a X-Large VM configured with 24 vCPUs and 58 GB of memory and requires 3213 GB of disk space. This option contains vCenter Server with an embedded Platform Services Controller for managing up to 2000 hosts and 35,000 VMs.</Description>
    </Configuration>
  </DeploymentOptionSection>
